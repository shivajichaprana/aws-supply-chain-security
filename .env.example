# Copy to .env and populate. .env is git-ignored.

# AWS
AWS_REGION=us-east-1
AWS_PROFILE=default
AWS_ACCOUNT_ID=123456789012

# Terraform
TF_VAR_environment=dev
TF_VAR_project_tag=aws-supply-chain-security

# Slack webhook for Security Hub findings (set in Secrets Manager in real envs)
SLACK_WEBHOOK_URL=

# Cosign / Signer
COSIGN_PASSWORD=
SIGNER_PROFILE_NAME=aws-supply-chain-security
